@model IEnumerable<SmartInventory.Model.Supplier>

<h2>Supplier List</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Add Supplier</a>

<table class="table table-bordered text-center">
    <thead>
        <tr>
            <th>Name</th>
            <th>Phone</th>
            <th>Address</th>
            <th width="200">Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var supplier in Model)
        {
            <tr>
                <td>@supplier.Name</td>
                <td>@supplier.Phone</td>
                <td>@supplier.Address</td>

                <td>
                    <a asp-action="Details" asp-route-id="@supplier.id" class="btn btn-info btn-sm">View</a>

                    <a asp-action="Edit" asp-route-id="@supplier.id" class="btn btn-warning btn-sm">Edit</a>

                    <a asp-action="Delete" asp-route-id="@supplier.id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>