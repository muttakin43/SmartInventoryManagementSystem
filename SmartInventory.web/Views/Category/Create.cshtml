@model SmartInventory.Contract.Request.CreateCategoryRequest

@{
    ViewData["HeaderTitle"] = "Create Category";
    ViewData["BreadCrumbFirst"] = "Home";
    ViewData["BreadCrumbActive"] = "Category";
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">

        <!-- Card -->
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

            <!-- Header -->
            <div class="card-header text-white"
                 style="background: linear-gradient(135deg,#17a2b8,#0d6efd);">
                <div class="d-flex align-items-center">
                    <i class="fas fa-layer-group fa-lg mr-2"></i>
                    <h4 class="mb-0 font-weight-bold">Create New Category</h4>
                </div>
                <small class="d-block mt-1 opacity-75">
                    Add a new product category to organize your inventory
                </small>
            </div>

            <!-- Body -->
            <form asp-action="Create" method="post">
                <div class="card-body p-5">

                    <!-- Validation -->
                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger rounded-3 py-2"></div>

                    <!-- Category Name -->
                    <div class="form-group mb-4">
                        <label asp-for="CategoryName" class="font-weight-semibold text-secondary"></label>

                        <div class="input-icon">
                            <i class="fas fa-tag"></i>
                            <input asp-for="CategoryName"
                                   class="form-control form-control-lg custom-input"
                                   placeholder="Enter category name" />
                        </div>

                        <span asp-validation-for="CategoryName" class="text-danger small"></span>
                    </div>

                    <!-- Description -->
                    <div class="form-group mb-4">
                        <label asp-for="Description" class="font-weight-semibold text-secondary"></label>

                        <textarea asp-for="Description"
                                  rows="4"
                                  class="form-control custom-input"
                                  placeholder="Write category description..."></textarea>

                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                </div>

                <!-- Footer -->
                <div class="card-footer bg-white border-0 px-5 py-4 d-flex justify-content-between">

                    <a asp-action="Index"
                       class="btn btn-light border px-4 rounded-pill">
                        <i class="fas fa-arrow-left mr-1"></i> Back
                    </a>

                    <button type="submit"
                            class="btn btn-primary px-5 rounded-pill shadow-sm">
                        <i class="fas fa-save mr-1"></i> Create Category
                    </button>

                </div>
            </form>

        </div>
    </div>
</div>

<!-- Custom Style -->
<style>
    .custom-input {
        border-radius: 12px;
        border: 1px solid #e4e6ef;
        transition: 0.3s;
        padding-left: 44px;
    }

        .custom-input:focus {
            border-color: #17a2b8;
            box-shadow: 0 0 0 0.2rem rgba(23,162,184,.15);
        }

    .input-icon {
        position: relative;
    }

        .input-icon i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #17a2b8;
        }

    textarea.custom-input {
        padding-left: 16px;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}