@model SmartInventory.Contract.Request.PurchaseCreateRequest

@{
    ViewData["HeaderTitle"] = "Create Purchase";
    ViewData["BreadCrumbFirst"] = "Home";
    ViewData["BreadCrumbActive"] = "Purchase";
}

<h2>Create Purchase</h2>

<form asp-action="Create" method="post">

    <!-- ✅ FIX 1: Supplier Dropdown ADD -->
    <div class="mb-3">
        <label>Supplier</label>
        <select asp-for="SupplierId" class="form-control">
            <option value="">Select Supplier</option>
            @foreach (var s in ViewBag.Suppliers)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
    </div>

    <!-- ✅ FIX 2: Table for Multiple Products -->
    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Quantity</th>
                <th>Price</th>
            </tr>
        </thead>

        <tbody id="tbody">
            <!-- ✅ FIRST ROW -->
            <tr>
                <td>
                    <select name="Items[0].ProductId" class="form-control">
                        <option value="">Select Product</option>
                        @foreach (var p in ViewBag.Products)
                        {
                            <option value="@p.Id">@p.ProductName</option>
                        }
                    </select>
                </td>

                <td>
                    <input name="Items[0].Quantity" class="form-control" />
                </td>

                <td>
                    <input name="Items[0].UnitPrice" class="form-control" />
                </td>
            </tr>
        </tbody>
    </table>

    <!-- ✅ FIX 3: Add More Button -->
    <button type="button" class="btn btn-secondary mb-3" onclick="addRow()">
        + Add Product
    </button>

    <br />

    <button type="submit" class="btn btn-success">
        Save Purchase
    </button>

</form>

<!-- ✅ FIX 4: Dynamic Row Script -->
<script>
    let index = 0;

    function addRow() {
        index++;

        let options = `
            <option value="">Select Product</option>
            @foreach (var p in ViewBag.Products)
            {
                    <option value="@p.Id">@p.ProductName</option>
            }
        `;

        let row = `
        <tr>
            <td>
                <select name="Items[${index}].ProductId" class="form-control">
                    ${options}
                </select>
            </td>
            <td>
                <input name="Items[${index}].Quantity" class="form-control" />
            </td>
            <td>
                <input name="Items[${index}].UnitPrice" class="form-control" />
            </td>
        </tr>
        `;

        document.getElementById("tbody").insertAdjacentHTML('beforeend', row);
    }
</script>