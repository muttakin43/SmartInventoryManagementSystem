
@model SmartInventory.Contract.Request.SaleCreateRequest

@{

    ViewData["HeaderTitle"] = "Create Sale";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Sale";
}

<form asp-action="Create" method="post">

    <!-- 🔥 Customer -->
    <div class="form-group">
        <label>Customer</label>
        <select name="CustomerId" class="form-control">
            <option value="">-- Select Customer --</option>
            @foreach (var c in ViewBag.Customers)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
    </div>

    <!-- 🔥 Date -->
    <div class="form-group mt-2">
        <label>Sale Date</label>
        <input type="date" name="SaleDate" class="form-control" />
    </div>

    <!-- 🔥 Products -->
    <div id="productsContainer"></div>

    <button type="button" class="btn btn-primary mt-2" onclick="addRow()">➕ Add Product</button>

    <br /><br />

    <button type="submit" class="btn btn-success">💾 Save Sale</button>
</form>

<!-- Template -->
<div id="productTemplate" style="display:none;">
    <div class="product-row border p-3 mb-2">
        <label>Product</label>
        <select class="form-control product-select">
            @foreach (var p in ViewBag.Products)
            {
                <option value="@p.id">@p.ProductName</option>
            }
        </select>

        <label class="mt-2">Quantity</label>
        <input type="number" class="form-control quantity" />

        <label class="mt-2">Price</label>
        <input type="number" class="form-control price" />

        <button type="button" class="btn btn-danger mt-2" onclick="removeRow(this)">Remove</button>
    </div>
</div>
@section Scripts {
<script>

    // 🔥 Page load হলে 1টা row auto add হবে
    document.addEventListener("DOMContentLoaded", function () {
        addRow();
    });

    // 🔥 Add Row
    function addRow() {
        var container = document.getElementById('productsContainer');
        var template = document.getElementById('productTemplate').innerHTML;

        var div = document.createElement('div');
        div.innerHTML = template;

        container.appendChild(div.firstElementChild);

        reIndex();
    }

    // 🔥 Remove Row
    function removeRow(button) {
        var row = button.closest('.product-row');
        var container = document.getElementById('productsContainer');

        if (container.children.length > 1) {
            row.remove();
            reIndex();
        }
    }

    // 🔥 Index Fix (MOST IMPORTANT)
    function reIndex() {
        var rows = document.querySelectorAll('#productsContainer .product-row');

        rows.forEach((row, index) => {

            row.querySelector('.product-select').name = `SaleDetails[${index}].ProductId`;
            row.querySelector('.quantity').name = `SaleDetails[${index}].Quantity`;
            row.querySelector('.price').name = `SaleDetails[${index}].Price`;

        });
    }

</script>
}