@model SmartInventory.Contract.Request.SaleCreateRequest

@{
    ViewData["HeaderTitle"] = "Create Sale";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Sale";
}

<div class="container-fluid">


   

    <form asp-action="Create" method="post">

        <!-- 🔷 MAIN CARD -->
        <div class="card shadow-sm border-0">

            <div class="card-body">

                <!-- 🔹 CUSTOMER + DATE -->
                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Customer</label>
                        <select name="CustomerId" class="form-select shadow-sm">
                            <option value="">-- Select Customer --</option>
                            @foreach (var c in ViewBag.Customers)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Sale Date</label>
                        <input type="date" name="SaleDate" class="form-control shadow-sm" />
                    </div>

                </div>

                <hr class="my-4" />

                <!-- 🔹 PRODUCTS HEADER -->
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">📦 Products</h5>
                    <button type="button" class="btn btn-sm btn-primary" onclick="addRow()">
                        ➕ Add Product
                    </button>
                </div>

                <!-- 🔹 PRODUCTS LIST -->
                <div id="productsContainer"></div>

            </div>

            <!-- 🔷 FOOTER ACTION -->
            <div class="card-footer bg-white d-flex justify-content-end gap-2">
                <button type="reset" class="btn btn-light border">Reset</button>
                <button type="submit" class="btn btn-success px-4">
                    💾 Save Sale
                </button>
            </div>

        </div>

    </form>
</div>

<!-- 🔷 PRODUCT TEMPLATE -->
<div id="productTemplate" style="display:none;">
    <div class="product-row card border-0 shadow-sm mb-3">
        <div class="card-body">

            <div class="row g-3 align-items-end">

                <div class="col-md-5">
                    <label class="form-label">Product</label>
                    <select class="form-select product-select">
                        @foreach (var p in ViewBag.Products)
                        {
                            <option value="@p.id">@p.ProductName</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Quantity</label>
                    <input type="number" class="form-control quantity" placeholder="0" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Price</label>
                    <input type="number" class="form-control price" placeholder="0.00" />
                </div>

                <div class="col-md-1 text-end">
                    <button type="button" class="btn btn-outline-danger w-100" onclick="removeRow(this)">
                        ✖
                    </button>
                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>

        document.addEventListener("DOMContentLoaded", function () {
            addRow();
        });

        function addRow() {
            var container = document.getElementById('productsContainer');
            var template = document.getElementById('productTemplate').innerHTML;

            var div = document.createElement('div');
            div.innerHTML = template;

            container.appendChild(div.firstElementChild);

            reIndex();
        }

        function removeRow(button) {
            var row = button.closest('.product-row');
            var container = document.getElementById('productsContainer');

            if (container.children.length > 1) {
                row.remove();
                reIndex();
            }
        }

        function reIndex() {
            var rows = document.querySelectorAll('#productsContainer .product-row');

            rows.forEach((row, index) => {

                row.querySelector('.product-select').name = `SaleDetails[${index}].ProductId`;
                row.querySelector('.quantity').name = `SaleDetails[${index}].Quantity`;
                row.querySelector('.price').name = `SaleDetails[${index}].Price`;

            });
        }

    </script>
}