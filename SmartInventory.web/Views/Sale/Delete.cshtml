@model IList<SmartInventory.Model.Sale>

@{
    ViewData["HeaderTitle"] = "Delete Sale";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Sale";
}


<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Sale Id</th>
            <th>Date</th>
            <th>Total Amount</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var sale in Model)
        {
            <tr>
                <td>@sale.id</td>
                <td>@sale.SaleDate.ToString("yyyy-MM-dd")</td>
                <td>@sale.TotalAmount</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@sale.id" class="btn btn-sm btn-primary">Edit</a>

                    <form asp-action="Delete" asp-route-id="@sale.id" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('Are you sure you want to delete this sale?');">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>