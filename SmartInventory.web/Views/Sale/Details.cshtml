@model IEnumerable<SmartInventory.Model.Sale>

@{
    ViewData["HeaderTitle"] = "Sale Details";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Sale Details";

    // Get the first sale from the collection for display
    var sale = Model.FirstOrDefault();
}

<h2>Sale Details</h2>

@if (sale != null)
{
    <p><strong>Customer:</strong> @sale.Customer?.Name</p>
    <p><strong>Date:</strong> @sale.SaleDate</p>
    <p><strong>Total:</strong> @sale.TotalAmount</p>

    <h4>Products</h4>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Product</th>
                <th>Qty</th>
                <th>Price</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var d in sale.SaleDetails)
            {
                <tr>
                    <td>@d.Product?.ProductName</td>
                    <td>@d.Quantity</td>
                    <td>@d.Price</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No sale details available.</p>
}

<a asp-action="Index" class="btn btn-secondary">Back</a>