@model IEnumerable<SmartInventory.Model.Sale>

@{
    ViewData["HeaderTitle"] = "Sale Details";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Sale Details";
}


<h2>Sales List</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Create Sale</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Sale Id</th>
            <th>Total Amount</th>
            <th>Date</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.id</td>
                <td>@item.TotalAmount.ToString("0.00")</td>
                <td>@item.SaleDate.ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.id"
                       class="btn btn-info btn-sm">
                        Details
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>