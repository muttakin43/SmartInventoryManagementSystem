@model SmartInventory.Contract.Request.SaleCreateRequest

@{
    ViewData["HeaderTitle"] = "Edit Sale";
    ViewData["BreadcrumbFirst"] = "Home";
    ViewData["BreadcrumbActive"] = "Sale";
}

<form asp-action="Edit" asp-route-id="@ViewBag.SaleId" method="post">

    <!-- Customer -->
    <div class="form-group">
        <label>Customer</label>
        <select name="CustomerId" class="form-control">
            @foreach (var c in ViewBag.Customers)
            {
                if (c.Id == Model.CustomerId)
                {
                    <option value="@c.Id" selected>@c.Name</option>
                }
                else
                {
                    <option value="@c.Id">@c.Name</option>
                }
            }
        </select>
    </div>

    <!-- Date -->
    <div class="form-group mt-2">
        <label>Date</label>
        <input type="date" name="SaleDate"
               value="@Model.SaleDate.ToString("yyyy-MM-dd")"
               class="form-control" />
    </div>

    <div id="productsContainer">
        @for (int i = 0; i < Model.SaleDetails.Count; i++)
        {
            <div class="product-row border p-3 mb-2">

                <label>Product</label>
                <select name="SaleDetails[@i].ProductId" class="form-control">
                    @foreach (var p in ViewBag.Products)
                    {
                        if (p.id == Model.SaleDetails[i].ProductId)
                        {
                            <option value="@p.id" selected>@p.ProductName</option>
                        }
                        else
                        {
                            <option value="@p.id">@p.ProductName</option>
                        }
                    }
                </select>

                <label class="mt-2">Qty</label>
                <input type="number" name="SaleDetails[@i].Quantity"
                       value="@Model.SaleDetails[i].Quantity"
                       class="form-control" />

                <label class="mt-2">Price</label>
                <input type="number" name="SaleDetails[@i].Price"
                       value="@Model.SaleDetails[i].Price"
                       class="form-control" />

                <button type="button" class="btn btn-danger mt-2" onclick="removeRow(this)">Remove</button>
            </div>
        }
    </div>

    <button type="button" class="btn btn-primary mt-2" onclick="addRow()">➕ Add</button>

    <br /><br />

    <button type="submit" class="btn btn-success">Update</button>
</form>

@section Scripts {
<script>
function addRow() {
    let container = document.getElementById('productsContainer');
    let index = container.children.length;

    let options = `@foreach (var p in ViewBag.Products) {
        <option value="@p.id">@p.ProductName</option>
    }`;

    let row = document.createElement('div');
    row.classList.add('product-row','border','p-3','mb-2');

    row.innerHTML = `
        <select name="SaleDetails[${index}].ProductId" class="form-control">
            ${options}
        </select>
        <input type="number" name="SaleDetails[${index}].Quantity" class="form-control mt-2"/>
        <input type="number" name="SaleDetails[${index}].Price" class="form-control mt-2"/>
        <button type="button" onclick="removeRow(this)" class="btn btn-danger mt-2">Remove</button>
    `;

    container.appendChild(row);
}

function removeRow(btn){
    let row = btn.parentElement;
    if(document.querySelectorAll('.product-row').length > 1){
        row.remove();
    }
}
</script>
}